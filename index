// SIMULADOR
// ═══════════════════════════════════════════════════════════
async function fetchMacro() {
  try {
    const r = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 200,
        tools: [{type:'web_search_20250305', name:'web_search'}],
        system: 'Retorne SOMENTE JSON sem markdown: {"selic":0.0,"cdi":0.0,"ipca":0.0} com valores atuais em % ao ano do Brasil.',
        messages: [{role:'user', content:'Selic atual, CDI e IPCA 12 meses Brasil. So o JSON.'}]
      })
    });
    const d = await r.json();
    const text = d.content.filter(b => b.type === 'text').map(b => b.text).join('');
    const parsed = JSON.parse(text.replace(/```json|```/g, '').trim());
    macroData = parsed;
    document.getElementById('m-selic').textContent = parsed.selic.toFixed(2);
    document.getElementById('m-cdi').textContent = parsed.cdi.toFixed(2);
    document.getElementById('m-ipca').textContent = parsed.ipca.toFixed(2);
  } catch(e) {
    document.getElementById('m-selic').textContent = macroData.selic;
    document.getElementById('m-cdi').textContent = macroData.cdi;
    document.getElementById('m-ipca').textContent = macroData.ipca;
  }
  renderSimulador();
}

function renderSimulador() {
  const slider = document.getElementById('sim-capital');
  if (!slider) return;
  const capital = parseInt(slider.value || 500000);
  const label = document.getElementById('sim-capital-label');
  if (label) label.textContent = capital >= 1000000 ? 'R$' + (capital / 1000000).toFixed(1) + 'M' : 'R$' + Math.round(capital / 1000) + 'k';
  const cdi = macroData.cdi / 100, selic = macroData.selic / 100, ipca = macroData.ipca / 100;
  const rendCDB = (capital * cdi * 0.90) / 12;
  const rendTesouro = (capital * selic * 0.85) / 12;
  const rendFII = (capital * 0.085) / 12;
  const rendReal = rendCDB - (capital * ipca / 12);
  const fmt = v => 'R$' + Math.round(v).toLocaleString('pt-BR');
  const result = document.getElementById('sim-result');
  if (!result) return;
  result.innerHTML =
    '<div class="sim-card"><div class="sim-card-label">CDB 90% CDI</div><div class="sim-card-val green">' + fmt(rendCDB) + '/mes</div><div class="sim-card-sub">IR ja descontado</div></div>' +
    '<div class="sim-card"><div class="sim-card-label">Tesouro Selic</div><div class="sim-card-val blue">' + fmt(rendTesouro) + '/mes</div><div class="sim-card-sub">liquido estimado</div></div>' +
    '<div class="sim-card"><div class="sim-card-label">FIIs (~8,5% a.a.)</div><div class="sim-card-val purple">' + fmt(rendFII) + '/mes</div><div class="sim-card-sub">isento IR PF</div></div>' +
    '<div class="sim-card"><div class="sim-card-label">Rendimento real</div><div class="sim-card-val ' + (rendReal > 0 ? 'amber' : 'red') + '">' + fmt(rendReal) + '/mes</div><div class="sim-card-sub">descontada inflacao</div></div>';
  const badge = document.getElementById('meta-passiva-badge');
  if (badge) {
    const pct = Math.round((rendCDB / 7800) * 100);
    const capitalMeta = Math.ceil(7800 * 12 / cdi / 0.90);
    badge.innerHTML = '<div class="meta-badge"><span class="meta-badge-txt">META R$7.800/mes: ' + pct + '% atingido · capital necessario: R$' + Math.round(capitalMeta / 1000) + 'k</span></div>';
  }
}

// ═══════════════════════════════════════════════════════════
// GLOBE 3D
// ═══════════════════════════════════════════════════════════
function initGlobe() {
  const canvas = document.getElementById('globe-canvas');
  if (!canvas) return;
  const W = canvas.offsetWidth || 340;
  canvas.width = W; canvas.height = W;
  const ctx = canvas.getContext('2d');
  const cx = W / 2, cy = W / 2, R = W * 0.42;
  const VISITED_ISO = new Set(TRAVEL_DONE.map(t => t.iso));
  let rotX = 0.3, rotY = 0;
  let dragging = false, lastX = 0, lastY = 0;

  function project(lat, lon) {
    const phi = (90 - lat) * Math.PI / 180;
    const theta = (lon + rotY * 180 / Math.PI) * Math.PI / 180;
    const sinPhi = Math.sin(phi);
    const x = R * sinPhi * Math.sin(theta);
    const y = R * (Math.cos(rotX) * Math.cos(phi) - Math.sin(rotX) * sinPhi * Math.cos(theta));
    const z = R * (Math.sin(rotX) * Math.cos(phi) + Math.cos(rotX) * sinPhi * Math.cos(theta));
    return {x: cx + x, y: cy - y, z, visible: z > -R * 0.1};
  }

  const COUNTRIES = [
    {iso:'BRA',lat:-14,lon:-51},{iso:'USA',lat:38,lon:-97},{iso:'ARG',lat:-34,lon:-64},
    {iso:'PRY',lat:-23,lon:-58},{iso:'CHL',lat:-35,lon:-71},{iso:'MEX',lat:23,lon:-102},
    {iso:'PER',lat:-10,lon:-76},{iso:'GBR',lat:54,lon:-2},{iso:'FRA',lat:46,lon:2},
    {iso:'DEU',lat:51,lon:10},{iso:'ITA',lat:42,lon:12},{iso:'ESP',lat:40,lon:-4},
    {iso:'PRT',lat:39,lon:-8},{iso:'NLD',lat:52,lon:5},{iso:'BEL',lat:51,lon:4},
    {iso:'HUN',lat:47,lon:19},{iso:'GRC',lat:39,lon:22},{iso:'HRV',lat:45,lon:16},
    {iso:'JPN',lat:36,lon:138},{iso:'AUS',lat:-25,lon:134},{iso:'ZAF',lat:-29,lon:25},
    {iso:'CHN',lat:35,lon:105},{iso:'IND',lat:20,lon:79},{iso:'RUS',lat:61,lon:105},
    {iso:'CAN',lat:56,lon:-96},{iso:'THA',lat:15,lon:101},
  ];

  const CONTINENTS = [
    {pts:[[-4,-80],[1,-78],[4,-77],[8,-77],[11,-75],[12,-72],[11,-68],[10,-62],[8,-60],[6,-57],[4,-52],[2,-50],[0,-50],[-4,-37],[-8,-35],[-10,-37],[-13,-39],[-16,-39],[-20,-40],[-23,-43],[-28,-49],[-30,-51],[-33,-53],[-35,-58],[-38,-62],[-42,-65],[-45,-66],[-50,-69],[-54,-68],[-56,-68],[-55,-65],[-52,-58],[-50,-50],[-40,-62],[-35,-60],[-28,-50],[-20,-41],[-12,-38],[-8,-35],[-4,-37],[-2,-40],[0,-50],[2,-50],[4,-52],[6,-57],[8,-60],[8,-63],[10,-62],[12,-68],[10,-72],[8,-77],[4,-77],[1,-78],[-4,-80]]},
    {pts:[[70,-140],[71,-135],[70,-125],[65,-125],[60,-140],[58,-137],[55,-130],[50,-127],[48,-125],[45,-124],[35,-121],[32,-117],[28,-110],[22,-106],[20,-105],[15,-92],[10,-84],[8,-83],[8,-78],[10,-75],[12,-72],[10,-63],[12,-68],[15,-65],[18,-68],[20,-72],[22,-80],[25,-80],[28,-80],[30,-81],[32,-81],[35,-76],[37,-76],[40,-74],[42,-70],[45,-67],[47,-53],[52,-56],[55,-60],[58,-65],[60,-65],[62,-65],[65,-65],[68,-55],[70,-55],[72,-65],[72,-75],[75,-80],[78,-85],[80,-90],[80,-100],[75,-120],[70,-140]]},
    {pts:[[71,28],[70,20],[65,14],[60,5],[58,5],[55,8],[53,8],[52,5],[50,2],[48,-5],[44,-10],[38,-9],[36,-6],[36,2],[38,10],[40,18],[42,20],[42,28],[45,30],[47,38],[44,40],[42,44],[44,46],[48,46],[50,30],[52,25],[55,22],[58,25],[60,28],[63,26],[66,26],[68,28],[71,28]]},
    {pts:[[36,10],[37,12],[30,32],[28,34],[22,36],[15,42],[11,43],[8,48],[2,44],[0,42],[-5,40],[-12,40],[-18,36],[-26,34],[-34,26],[-35,20],[-30,18],[-25,15],[-20,12],[-15,12],[-12,15],[-10,15],[-8,15],[-5,10],[0,8],[4,2],[4,-2],[2,-10],[5,-5],[10,-17],[15,-17],[20,-17],[25,-15],[30,-10],[32,-5],[35,5],[36,10]]},
    {pts:[[70,30],[72,60],[70,90],[68,140],[65,150],[60,150],[55,135],[50,140],[45,136],[40,130],[35,127],[30,122],[25,120],[20,110],[15,100],[10,100],[5,100],[0,104],[-5,105],[-8,115],[-8,125],[-5,130],[0,128],[5,120],[10,110],[15,100],[20,93],[22,92],[20,87],[15,80],[8,77],[10,72],[22,60],[22,58],[28,50],[28,46],[32,44],[36,36],[40,36],[44,42],[48,46],[50,46],[52,40],[55,38],[55,30],[58,28],[62,28],[65,30],[68,30],[70,30]]},
    {pts:[[-12,130],[-15,136],[-18,140],[-22,150],[-28,154],[-34,151],[-38,147],[-38,140],[-35,137],[-32,134],[-28,115],[-22,114],[-18,122],[-14,128],[-12,130]]},
  ];

  function drawContinent(pts) {
    if (!pts || pts.length < 2) return;
    let started = false;
    ctx.beginPath();
    for (let i = 0; i < pts.length; i++) {
      const p = project(pts[i][0], pts[i][1]);
      if (!p.visible) { started = false; continue; }
      if (!started) { ctx.moveTo(p.x, p.y); started = true; }
      else ctx.lineTo(p.x, p.y);
    }
    ctx.closePath();
  }

  function drawGlobe() {
    ctx.clearRect(0, 0, W, W);
    ctx.save();
    ctx.beginPath();
    ctx.arc(cx, cy, R, 0, Math.PI * 2);
    ctx.clip();
    const grad = ctx.createRadialGradient(cx, cy, 0, cx, cy, R);
    grad.addColorStop(0, 'rgba(0,60,120,0.3)');
    grad.addColorStop(1, 'rgba(0,10,40,0.1)');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, W, W);
    ctx.lineWidth = 0.3;
    ctx.strokeStyle = 'rgba(0,180,255,0.08)';
    for (let lat = -80; lat <= 80; lat += 20) {
      ctx.beginPath(); let first = true;
      for (let lon = -180; lon <= 180; lon += 4) {
        const p = project(lat, lon);
        if (!p.visible) { first = true; continue; }
        if (first) { ctx.moveTo(p.x, p.y); first = false; } else ctx.lineTo(p.x, p.y);
      }
      ctx.stroke();
    }
    for (let lon = -180; lon <= 180; lon += 20) {
      ctx.beginPath(); let first = true;
      for (let lat = -90; lat <= 90; lat += 4) {
        const p = project(lat, lon);
        if (!p.visible) { first = true; continue; }
        if (first) { ctx.moveTo(p.x, p.y); first = false; } else ctx.lineTo(p.x, p.y);
      }
      ctx.stroke();
    }
    CONTINENTS.forEach(cont => {
      drawContinent(cont.pts);
      ctx.fillStyle = 'rgba(0,80,140,0.22)';
      ctx.fill();
      ctx.strokeStyle = 'rgba(0,180,255,0.45)';
      ctx.lineWidth = 0.8;
      ctx.stroke();
    });
    ctx.restore();
    ctx.beginPath();
    ctx.arc(cx, cy, R, 0, Math.PI * 2);
    ctx.strokeStyle = 'rgba(0,180,255,0.5)';
    ctx.lineWidth = 1.5;
    ctx.stroke();
    const sorted = COUNTRIES.map(c => { const p = project(c.lat, c.lon); return {...c, ...p}; })
      .filter(c => c.visible).sort((a, b) => a.z - b.z);
    sorted.forEach(c => {
      const visited = VISITED_ISO.has(c.iso);
      const depth = (c.z + R) / (2 * R);
      const alpha = 0.4 + depth * 0.6;
      if (visited) {
        const dotR = 5;
        const glow = ctx.createRadialGradient(c.x, c.y, 0, c.x, c.y, dotR * 4);
        glow.addColorStop(0, `rgba(0,255,136,${alpha * 0.4})`);
        glow.addColorStop(1, 'rgba(0,255,136,0)');
        ctx.beginPath(); ctx.arc(c.x, c.y, dotR * 4, 0, Math.PI * 2);
        ctx.fillStyle = glow; ctx.fill();
        ctx.beginPath(); ctx.arc(c.x, c.y, dotR, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(0,255,136,${alpha})`; ctx.fill();
        ctx.strokeStyle = `rgba(255,255,255,${alpha * 0.9})`; ctx.lineWidth = 1; ctx.stroke();
        const entry = TRAVEL_DONE.find(t => t.iso === c.iso);
        if (entry) {
          ctx.font = `${Math.round(12 * depth + 8)}px serif`;
          ctx.textAlign = 'center'; ctx.textBaseline = 'bottom';
          ctx.fillText(entry.flag, c.x, c.y - dotR - 2);
        }
      } else {
        ctx.beginPath(); ctx.arc(c.x, c.y, 2.5, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(0,100,180,${alpha * 0.35})`; ctx.fill();
      }
    });
  }

  function animate() { rotY += 0.003; if (!dragging) {} drawGlobe(); requestAnimationFrame(animate); }
  canvas.addEventListener('mousedown', e => { dragging = true; lastX = e.clientX; lastY = e.clientY; });
  canvas.addEventListener('mousemove', e => {
    if (!dragging) return;
    rotY += (e.clientX - lastX) * 0.01; rotX += (e.clientY - lastY) * 0.01;
    rotX = Math.max(-Math.PI/2, Math.min(Math.PI/2, rotX));
    lastX = e.clientX; lastY = e.clientY;
  });
  canvas.addEventListener('mouseup', () => dragging = false);
  canvas.addEventListener('mouseleave', () => dragging = false);
  canvas.addEventListener('touchstart', e => { dragging = true; lastX = e.touches[0].clientX; lastY = e.touches[0].clientY; e.preventDefault(); }, {passive:false});
  canvas.addEventListener('touchmove', e => {
    if (!dragging) return;
    rotY += (e.touches[0].clientX - lastX) * 0.012; rotX += (e.touches[0].clientY - lastY) * 0.012;
    rotX = Math.max(-Math.PI/2, Math.min(Math.PI/2, rotX));
    lastX = e.touches[0].clientX; lastY = e.touches[0].clientY; e.preventDefault();
  }, {passive:false});
  canvas.addEventListener('touchend', () => dragging = false);
  animate();
}

