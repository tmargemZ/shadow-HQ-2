    d.textContent = i <= state.cigCount ? '🚬' : '·';
    dots.appendChild(d);
  }
  const st = document.getElementById('cig-st');
  if (!state.cigCount) { st.textContent = '[ NENHUM HOJE ]'; st.style.color = 'var(--green)'; }
  else if (state.cigCount <= 3) { st.textContent = `[ ${state.cigCount} de 3 · ok ]`; st.style.color = 'var(--amber)'; }
  else { st.textContent = `[ ${state.cigCount} · +${state.cigCount - 3} ACIMA ]`; st.style.color = 'var(--red)'; }
}
