      })
    });
    const data = await res.json();
    const text = data.content.filter(b => b.type === 'text').map(b => b.text).join('');
    const parsed = JSON.parse(text.replace(/```json|```/g, '').trim());
    const vagas = parsed.vagas || [];
    list.innerHTML = '';
    if (!vagas.length) {
      list.innerHTML = '<div class="job-loading">Nenhuma vaga encontrada. Tente novamente.</div>';
    } else {
      vagas.forEach(v => {
        const card = document.createElement('div');
        card.className = 'job-card';
        const tc = v.tipo && v.tipo.toLowerCase().includes('remoto') ? 'job-tag remote' : 'job-tag';
        card.innerHTML = `<div class="job-title">${v.titulo||'—'}</div><div class="job-company">${v.empresa||'—'}</div><span class="${tc}">${v.tipo||'presencial'}</span>${v.link ? '<a class="job-link" href="' + v.link + '" target="_blank">' + v.link + '</a>' : ''}`;
        list.appendChild(card);
      });
      meta.style.display = 'block';
      meta.textContent = 'ultima busca: ' + new Date().toLocaleString('pt-BR') + ' · ' + vagas.length + ' vagas';
      renderLinkedinPreview(vagas);
    }
  } catch(e) {
    list.innerHTML = '<div class="job-loading">Erro na busca (CORS). Use os links diretos abaixo.</div>';
  }
  btn.disabled = false;
  btn.textContent = '⚡ Buscar Vagas Agora';
}

function renderLinkedinPreview(vagas) {
  const preview = document.getElementById('ln-preview');
  if (!preview) return;
  const top3 = vagas.slice(0, 3);
  preview.innerHTML = top3.map((v, i) =>
    '<div class="ln-item"><div class="ln-num">#' + (i+1) + '</div><div class="ln-title">' + (v.titulo||'—') + ' · ' + (v.empresa||'') + '</div></div>'
  ).join('');
}

