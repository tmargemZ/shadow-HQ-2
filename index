<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Shadow HQ">
<title>Shadow HQ · 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;500;600;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
:root{
  --bg:#040810;--surface:#070d1a;--panel:#0a1220;
  --border:#0d2a4a;--glow:#1a5a8a;
  --blue:#00b4ff;--blue-d:rgba(0,180,255,0.1);
  --green:#00ff88;--green-d:rgba(0,255,136,0.1);
  --amber:#ffb800;--amber-d:rgba(255,184,0,0.1);
  --red:#ff3a3a;--red-d:rgba(255,58,58,0.1);
  --purple:#9966ff;--purple-d:rgba(153,102,255,0.1);
  --text:#c8dff0;--muted:#4a6a8a;
  --font:'Rajdhani',sans-serif;--mono:'Share Tech Mono',monospace;
}
html,body{background:var(--bg);font-family:var(--font);color:var(--text);min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,10,30,0.15) 3px,rgba(0,10,30,0.15) 4px);pointer-events:none;z-index:999;}

#notif{position:fixed;top:12px;left:50%;transform:translateX(-50%) translateY(-90px);background:var(--panel);border:1px solid var(--blue);padding:8px 16px;z-index:9999;min-width:260px;max-width:92vw;text-align:center;transition:transform 0.3s ease;box-shadow:0 0 20px rgba(0,180,255,0.25);}
#notif.show{transform:translateX(-50%) translateY(0);}
.n-head{font-size:11px;font-weight:700;letter-spacing:0.2em;color:var(--blue);margin-bottom:4px;}
.n-line{height:1px;background:linear-gradient(90deg,transparent,var(--blue),transparent);margin-bottom:5px;}
.n-body{font-family:var(--mono);font-size:10px;color:var(--text);}

.dashboard{max-width:480px;margin:0 auto;padding:10px 10px 90px;}

.hdr{border:1px solid var(--glow);background:var(--panel);padding:12px 14px;margin-bottom:10px;position:relative;overflow:hidden;clip-path:polygon(0 0,calc(100% - 14px) 0,100% 14px,100% 100%,0 100%);}
.hdr::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--blue),transparent);animation:scanh 3s linear infinite;}
.hdr-row{display:flex;justify-content:space-between;align-items:flex-start;}
.pname{font-size:20px;font-weight:700;letter-spacing:0.1em;color:#fff;text-shadow:0 0 18px rgba(0,180,255,0.6);}
.prank{font-family:var(--mono);font-size:9px;color:var(--blue);letter-spacing:0.1em;margin-top:2px;}
.hdr-r{text-align:right;}
.hdr-date{font-family:var(--mono);font-size:8px;color:var(--muted);}
.hdr-status{font-family:var(--mono);font-size:8px;color:var(--green);margin-top:2px;}
.sdot{display:inline-block;width:5px;height:5px;border-radius:50%;background:var(--green);margin-right:3px;animation:pulse 2s ease-in-out infinite;}

.tabs{display:flex;gap:0;margin-bottom:10px;border:1px solid var(--border);overflow:hidden;}
.tab{flex:1;padding:9px 4px;text-align:center;font-size:11px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;cursor:pointer;background:var(--surface);color:var(--muted);border:none;transition:all 0.15s;font-family:var(--font);border-right:1px solid var(--border);}
.tab:last-child{border-right:none;}
.tab.active{background:var(--blue-d);color:var(--blue);border-bottom:2px solid var(--blue);}
.tab-content{display:none;}
.tab-content.active{display:block;}

.mode-bar{display:flex;gap:6px;justify-content:flex-end;margin-bottom:10px;}
.mbtn{background:transparent;border:1px solid var(--glow);color:var(--muted);font-family:var(--font);font-weight:700;font-size:10px;letter-spacing:0.1em;padding:5px 12px;cursor:pointer;text-transform:uppercase;transition:all 0.15s;}
.mbtn.active{border-color:var(--blue);color:var(--blue);background:var(--blue-d);}

.panel{background:var(--panel);border:1px solid var(--border);position:relative;overflow:hidden;margin-bottom:8px;}
.panel::after{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--glow),transparent);opacity:0.5;}
.ph{display:flex;align-items:center;gap:8px;padding:8px 12px;border-bottom:1px solid var(--border);background:rgba(0,0,0,0.25);}
.pi{font-size:15px;line-height:1;}
.pt{font-size:11px;font-weight:700;letter-spacing:0.16em;text-transform:uppercase;}
.pt.blue{color:var(--blue);}.pt.green{color:var(--green);}.pt.amber{color:var(--amber);}.pt.purple{color:var(--purple);}
.pb{padding:10px 12px;}

.sdiv{display:flex;align-items:center;gap:8px;margin:12px 0 8px;}
.sdl{flex:1;height:1px;background:linear-gradient(90deg,var(--glow),transparent);}
.sdr{flex:1;height:1px;background:linear-gradient(90deg,transparent,var(--glow));}
.sdt{font-family:var(--mono);font-size:8px;letter-spacing:0.18em;color:var(--muted);text-transform:uppercase;white-space:nowrap;}

.g2{display:grid;grid-template-columns:1fr 1fr;gap:8px;}

.srow{margin-bottom:8px;}
.slabel{display:flex;justify-content:space-between;align-items:center;margin-bottom:4px;}
.sname{font-size:10px;font-weight:600;letter-spacing:0.08em;}
.sval{font-family:var(--mono);font-size:10px;}
.sval.blue{color:var(--blue);}.sval.green{color:var(--green);}.sval.amber{color:var(--amber);}.sval.purple{color:var(--purple);}
.btrack{height:3px;background:rgba(255,255,255,0.05);border-radius:2px;overflow:hidden;}
.bfill{height:100%;border-radius:2px;transition:width 0.6s ease;}
.bfill.blue{background:linear-gradient(90deg,#004488,var(--blue));}
.bfill.green{background:linear-gradient(90deg,#004422,var(--green));}
.bfill.amber{background:linear-gradient(90deg,#664400,var(--amber));}
.bfill.purple{background:linear-gradient(90deg,#220055,var(--purple));}

.ez{margin-top:8px;}
.ez.hidden{display:none;}
.erow{display:flex;gap:5px;align-items:center;flex-wrap:wrap;margin-top:5px;}
.sinput{background:rgba(0,15,40,0.9);border:1px solid var(--glow);color:var(--text);font-family:var(--mono);font-size:11px;padding:5px 8px;outline:none;-webkit-appearance:none;width:85px;}
.sinput:focus{border-color:var(--blue);}
.sbtn{background:transparent;border:1px solid var(--blue);color:var(--blue);font-family:var(--font);font-weight:700;font-size:10px;letter-spacing:0.08em;padding:5px 10px;cursor:pointer;text-transform:uppercase;transition:all 0.15s;-webkit-appearance:none;white-space:nowrap;}
.sbtn:active{transform:scale(0.95);}
.sbtn.green{border-color:var(--green);color:var(--green);}
.sbtn.amber{border-color:var(--amber);color:var(--amber);}
.sbtn.purple{border-color:var(--purple);color:var(--purple);}
.sbtn.muted{border-color:var(--muted);color:var(--muted);}

.cig-dots{display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin:6px 0;}
.cdot{width:32px;height:32px;border-radius:4px;border:1px solid var(--muted);display:flex;align-items:center;justify-content:center;font-size:16px;transition:all 0.2s;}
.cdot.lit{border-color:var(--amber);background:var(--amber-d);}
.cdot.over{border-color:var(--red);background:var(--red-d);}
.cstatus{font-family:var(--mono);font-size:9px;letter-spacing:0.08em;text-align:center;margin-bottom:4px;}
.cgoal{font-family:var(--mono);font-size:8px;color:var(--muted);text-align:center;}
.cact{display:flex;gap:5px;justify-content:center;margin-top:8px;flex-wrap:wrap;}

.wc{margin-top:8px;}
.wc-label{font-size:8px;color:var(--muted);letter-spacing:0.1em;margin-bottom:5px;}
.wc-bars{display:flex;gap:3px;align-items:flex-end;height:40px;}
.wc-col{display:flex;flex-direction:column;align-items:center;gap:2px;flex:1;}
.wc-bar{width:100%;background:var(--green-d);border-top:2px solid var(--green);min-height:3px;}
.wc-day{font-family:var(--mono);font-size:7px;color:var(--muted);}
.wc-v{font-family:var(--mono);font-size:7px;color:var(--green);}
.wc-empty{font-family:var(--mono);font-size:8px;color:var(--muted);}

.gym-st{display:flex;gap:5px;margin-top:8px;}
.gstat{flex:1;background:rgba(0,0,0,0.3);border:1px solid var(--border);padding:6px 4px;text-align:center;}
.gstat-l{font-size:7px;color:var(--muted);letter-spacing:0.06em;margin-bottom:2px;}
.gstat-v{font-family:var(--mono);font-size:15px;}

.manga-big{text-align:center;padding:4px 0;}
.manga-n{font-family:var(--mono);font-size:38px;font-weight:700;color:var(--blue);text-shadow:0 0 16px rgba(0,180,255,0.4);line-height:1;}
.manga-s{font-size:8px;color:var(--muted);letter-spacing:0.1em;margin-top:3px;}

.iitem{display:flex;justify-content:space-between;align-items:flex-start;padding:7px 0;border-bottom:1px solid rgba(255,255,255,0.04);}
.iitem:last-child{border:none;}
.ileft{display:flex;align-items:center;gap:7px;}
.iicon{font-size:14px;}
.ilabel{font-size:12px;font-weight:600;letter-spacing:0.03em;}
.inote{font-size:8px;color:var(--muted);margin-top:1px;}
.iamt{font-family:var(--mono);font-size:12px;font-weight:600;}
.itotal{display:flex;justify-content:space-between;align-items:center;padding:8px 0 0;margin-top:5px;border-top:1px solid var(--glow);}
.itlbl{font-size:10px;font-weight:700;letter-spacing:0.12em;color:var(--muted);text-transform:uppercase;}
.itval{font-family:var(--mono);font-size:18px;font-weight:700;color:var(--green);text-shadow:0 0 10px rgba(0,255,136,0.3);}

.rblocks{display:flex;gap:6px;margin-bottom:8px;}
.rb{flex:1;background:rgba(0,0,0,0.3);border:1px solid var(--border);padding:7px 8px;}
.rb-l{font-size:7px;color:var(--muted);letter-spacing:0.1em;text-transform:uppercase;margin-bottom:3px;}
.rb-v{font-family:var(--mono);font-size:13px;font-weight:600;}
.rb-s{font-size:7px;color:var(--muted);margin-top:1px;}

.goals-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px;}
.gitem{display:flex;align-items:center;gap:6px;padding:8px 8px;background:rgba(0,0,0,0.2);border:1px solid var(--border);cursor:pointer;transition:all 0.15s;-webkit-user-select:none;user-select:none;}
.gitem:active{transform:scale(0.97);}
.gitem.done{border-color:rgba(0,255,136,0.25);background:rgba(0,255,136,0.04);}
.gcheck{width:12px;height:12px;border:1px solid var(--muted);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:8px;transition:all 0.2s;}
.gcheck.done{border-color:var(--green);color:var(--green);}
.gicon{font-size:13px;}
.gwrap{flex:1;min-width:0;}
.gtxt{font-size:11px;font-weight:600;letter-spacing:0.02em;}
.gtxt.done{color:var(--muted);text-decoration:line-through;}
.gsub{font-size:8px;color:var(--muted);}

/* MEDIA */
.media-tabs{display:flex;gap:0;margin-bottom:8px;border:1px solid var(--border);overflow:hidden;}
.mtab{flex:1;padding:7px 4px;text-align:center;font-size:10px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;cursor:pointer;background:var(--surface);color:var(--muted);border:none;transition:all 0.15s;font-family:var(--font);border-right:1px solid var(--border);}
.mtab:last-child{border-right:none;}
.mtab.active{background:var(--purple-d);color:var(--purple);border-bottom:2px solid var(--purple);}
.mcontent{display:none;}
.mcontent.active{display:block;}

.media-list{display:flex;flex-direction:column;gap:4px;}
.mitem{display:flex;align-items:center;gap:10px;padding:9px 10px;background:rgba(0,0,0,0.2);border:1px solid var(--border);}
.mitem-icon{font-size:17px;flex-shrink:0;}
.mitem-info{flex:1;min-width:0;}
.mitem-title{font-size:13px;font-weight:700;letter-spacing:0.03em;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.mitem-sub{font-size:8px;color:var(--muted);margin-top:1px;}
.mitem-score{font-family:var(--mono);font-size:18px;font-weight:700;flex-shrink:0;min-width:32px;text-align:right;}
.sg{color:var(--green);}.sb{color:var(--blue);}.sa{color:var(--amber);}.sr{color:var(--red);}.sn{color:var(--muted);}

.add-media{background:rgba(0,0,0,0.2);border:1px solid var(--border);padding:10px 12px;margin-top:8px;}
.add-title{font-size:9px;color:var(--muted);letter-spacing:0.14em;text-transform:uppercase;margin-bottom:8px;}
.add-fields{display:flex;flex-direction:column;gap:6px;}
.add-row{display:flex;gap:5px;}
.sinput-full{background:rgba(0,15,40,0.9);border:1px solid var(--glow);color:var(--text);font-family:var(--mono);font-size:11px;padding:5px 8px;outline:none;-webkit-appearance:none;flex:1;min-width:0;}
.sinput-full:focus{border-color:var(--blue);}
.sinput-sm{background:rgba(0,15,40,0.9);border:1px solid var(--glow);color:var(--text);font-family:var(--mono);font-size:11px;padding:5px 8px;outline:none;-webkit-appearance:none;width:70px;}

/* TRAVEL */
.travel-stats{display:flex;gap:8px;margin-bottom:10px;}
.tstat{flex:1;background:rgba(0,0,0,0.3);border:1px solid var(--glow);padding:10px 8px;text-align:center;}
.tstat-n{font-family:var(--mono);font-size:26px;font-weight:700;color:var(--blue);text-shadow:0 0 12px rgba(0,180,255,0.4);}
.tstat-l{font-size:8px;color:var(--muted);letter-spacing:0.12em;margin-top:2px;}

.titem{display:flex;align-items:center;gap:8px;padding:7px 10px;border-bottom:1px solid rgba(255,255,255,0.04);}
.titem:last-child{border:none;}
.titem-flag{font-size:18px;flex-shrink:0;}
.titem-info{flex:1;}
.titem-place{font-size:13px;font-weight:700;letter-spacing:0.03em;}
.titem-dates{font-size:8px;color:var(--muted);margin-top:1px;}
.titem-check{font-size:11px;color:var(--green);}

.wl-item{display:flex;align-items:center;gap:8px;padding:6px 10px;border-bottom:1px solid rgba(255,255,255,0.03);}
.wl-item:last-child{border:none;}
.wl-flag{font-size:15px;}
.wl-place{font-size:12px;font-weight:600;color:var(--muted);}

.footer{font-family:var(--mono);font-size:8px;color:var(--muted);text-align:center;padding:12px 0 6px;letter-spacing:0.14em;}

.renda-val.hidden{filter:blur(4px);user-select:none;pointer-events:none;}
.job-card{background:rgba(0,0,0,0.2);border:1px solid var(--border);padding:10px 12px;margin-bottom:6px;}
.job-card:hover{border-color:var(--glow);}
.job-title{font-size:13px;font-weight:700;letter-spacing:0.04em;color:var(--text);margin-bottom:3px;}
.job-company{font-size:11px;color:var(--blue);margin-bottom:2px;}
.job-meta{font-size:9px;color:var(--muted);font-family:var(--mono);}
.job-tag{display:inline-block;font-size:8px;padding:2px 6px;border-radius:2px;background:var(--green-d);color:var(--green);border:1px solid rgba(0,255,136,0.2);margin-right:4px;margin-top:4px;}
.job-tag.remote{background:var(--amber-d);color:var(--amber);border-color:rgba(255,184,0,0.2);}
.job-search-btn{width:100%;padding:10px;background:transparent;border:1px solid var(--blue);color:var(--blue);font-family:var(--font);font-weight:700;font-size:12px;letter-spacing:0.14em;cursor:pointer;text-transform:uppercase;transition:all 0.2s;margin-bottom:10px;}
.job-search-btn:active{transform:scale(0.98);}
.job-search-btn:hover{background:var(--blue-d);}
.job-search-btn:disabled{color:var(--muted);border-color:var(--muted);cursor:default;}
.job-loading{text-align:center;font-family:var(--mono);font-size:10px;color:var(--muted);padding:20px;letter-spacing:0.1em;}
.job-link{display:block;font-family:var(--mono);font-size:8px;color:var(--muted);margin-top:5px;text-decoration:none;word-break:break-all;}
.job-link:hover{color:var(--blue);}
.jobs-meta{font-family:var(--mono);font-size:8px;color:var(--muted);text-align:right;margin-bottom:8px;letter-spacing:0.08em;}

/* INVEST PASSWORD */
.inv-lock{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:30px 20px;gap:12px;}
.inv-lock-icon{font-size:40px;margin-bottom:4px;}
.inv-lock-title{font-family:var(--mono);font-size:11px;letter-spacing:0.2em;color:var(--muted);}
.inv-pin-row{display:flex;gap:8px;justify-content:center;margin:8px 0;}
.inv-pin-dot{width:14px;height:14px;border-radius:50%;border:1px solid var(--muted);background:transparent;transition:all 0.2s;}
.inv-pin-dot.filled{background:var(--blue);border-color:var(--blue);box-shadow:0 0 6px rgba(0,180,255,0.5);}
.inv-pin-dot.error{background:var(--red);border-color:var(--red);}
.inv-numpad{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;max-width:220px;margin:0 auto;}
.inv-key{background:rgba(0,0,0,0.3);border:1px solid var(--border);color:var(--text);font-family:var(--font);font-size:18px;font-weight:700;padding:14px;cursor:pointer;text-align:center;transition:all 0.15s;-webkit-user-select:none;}
.inv-key:active{background:var(--blue-d);border-color:var(--blue);transform:scale(0.94);}
.inv-key.del{font-size:13px;color:var(--muted);}
.inv-key.empty{border:none;background:transparent;cursor:default;}
.inv-content{display:none;}
.inv-content.unlocked{display:block;}
.inv-locked{display:block;}
.inv-locked.unlocked{display:none;}
.inv-logout{background:transparent;border:1px solid var(--muted);color:var(--muted);font-family:var(--mono);font-size:9px;padding:4px 10px;cursor:pointer;letter-spacing:0.1em;margin-left:auto;display:block;margin-bottom:8px;}

/* LINKEDIN PREVIEW */
.linkedin-preview{margin-bottom:10px;}
.ln-item{display:flex;align-items:center;gap:8px;padding:8px 10px;background:rgba(0,0,0,0.25);border:1px solid var(--border);margin-bottom:4px;}
.ln-num{font-family:var(--mono);font-size:10px;color:var(--muted);min-width:16px;}
.ln-title{font-size:12px;font-weight:700;color:var(--text);flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.ln-loading{font-family:var(--mono);font-size:9px;color:var(--muted);padding:8px 0;text-align:center;letter-spacing:0.1em;}
.ln-open{font-family:var(--mono);font-size:9px;padding:5px 10px;border:1px solid var(--blue);color:var(--blue);background:transparent;cursor:pointer;letter-spacing:0.08em;display:block;text-align:center;text-decoration:none;margin-top:4px;}

/* CLIMA */
.clima-widget{display:flex;align-items:center;gap:6px;margin-top:6px;padding:5px 8px;background:rgba(0,180,255,0.06);border:1px solid rgba(0,180,255,0.15);}
.clima-temp{font-family:var(--mono);font-size:16px;font-weight:700;color:var(--blue);}
.clima-desc{font-family:var(--mono);font-size:8px;color:var(--muted);letter-spacing:0.08em;}
.clima-icon{font-size:18px;}

/* COVER LETTER */
.cl-form{display:flex;flex-direction:column;gap:8px;}
.cl-textarea{background:rgba(0,15,40,0.9);border:1px solid var(--glow);color:var(--text);font-family:var(--mono);font-size:11px;padding:8px;outline:none;resize:vertical;min-height:80px;width:100%;}
.cl-textarea:focus{border-color:var(--blue);}
.cl-output{background:rgba(0,0,0,0.4);border:1px solid var(--border);padding:10px 12px;font-size:12px;line-height:1.7;color:var(--text);white-space:pre-wrap;margin-top:8px;max-height:320px;overflow-y:auto;}
.cl-loading{font-family:var(--mono);font-size:9px;color:var(--muted);text-align:center;padding:16px;letter-spacing:0.12em;}
.cl-copy-btn{background:transparent;border:1px solid var(--green);color:var(--green);font-family:var(--font);font-weight:700;font-size:10px;padding:5px 12px;cursor:pointer;letter-spacing:0.1em;margin-top:6px;}
.img-upload-label{display:flex;align-items:center;gap:6px;padding:7px 10px;border:1px dashed var(--glow);color:var(--muted);font-size:11px;font-family:var(--mono);cursor:pointer;letter-spacing:0.08em;}
.img-upload-label:hover{border-color:var(--blue);color:var(--blue);}
#vaga-img-input{display:none;}
.img-preview-name{font-size:9px;color:var(--green);margin-top:3px;font-family:var(--mono);}

/* SIMULADOR */
.sim-result{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:10px;}
.sim-card{background:rgba(0,0,0,0.3);border:1px solid var(--border);padding:8px 10px;text-align:center;}
.sim-card-label{font-size:8px;color:var(--muted);letter-spacing:0.08em;margin-bottom:4px;}
.sim-card-val{font-family:var(--mono);font-size:14px;font-weight:700;}
.sim-card-val.green{color:var(--green);}
.sim-card-val.blue{color:var(--blue);}
.sim-card-val.amber{color:var(--amber);}
.sim-card-val.purple{color:var(--purple);}
.sim-card-sub{font-size:7px;color:var(--muted);margin-top:2px;}
.macro-row{display:flex;gap:6px;margin-bottom:8px;flex-wrap:wrap;}
.macro-badge{font-family:var(--mono);font-size:9px;padding:3px 8px;border-radius:2px;background:rgba(0,0,0,0.3);border:1px solid var(--border);}
.macro-badge span{color:var(--blue);}
.sim-slider-label{display:flex;justify-content:space-between;align-items:center;margin-bottom:3px;}
.sim-slider-name{font-size:10px;font-weight:600;letter-spacing:0.06em;}
.sim-range{width:100%;margin:4px 0 10px;accent-color:var(--blue);}
.meta-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 10px;background:var(--green-d);border:1px solid rgba(0,255,136,0.2);margin-top:4px;}
.meta-badge-txt{font-family:var(--mono);font-size:9px;color:var(--green);}

/* GAMES EXTRAS */
.hltb-badge{font-family:var(--mono);font-size:8px;color:var(--amber);margin-top:2px;}
.countdown-card{background:rgba(0,0,0,0.25);border:1px solid var(--border);padding:9px 10px;margin-bottom:5px;display:flex;align-items:center;gap:10px;}
.cd-icon{font-size:20px;flex-shrink:0;}
.cd-info{flex:1;min-width:0;}
.cd-title{font-size:12px;font-weight:700;color:var(--text);}
.cd-date{font-size:9px;color:var(--muted);margin-top:1px;}
.cd-days{font-family:var(--mono);font-size:18px;font-weight:700;color:var(--blue);flex-shrink:0;}
.cd-label{font-size:8px;color:var(--muted);text-align:right;}

/* ═══ VOOS ═══ */
.voos-header{display:flex;align-items:center;gap:8px;margin-bottom:10px;}
.voos-badge{font-family:var(--mono);font-size:8px;padding:3px 8px;background:rgba(255,184,0,0.1);border:1px solid rgba(255,184,0,0.3);color:var(--amber);letter-spacing:0.1em;}
.voos-form{display:flex;flex-direction:column;gap:8px;margin-bottom:10px;}
.voos-row{display:flex;gap:6px;align-items:center;}
.voos-label{font-size:8px;color:var(--muted);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:3px;}
.voos-select{background:rgba(0,15,40,0.9);border:1px solid var(--glow);color:var(--text);font-family:var(--mono);font-size:11px;padding:5px 8px;outline:none;-webkit-appearance:none;flex:1;}
.voos-select:focus{border-color:var(--blue);}
.voos-input{background:rgba(0,15,40,0.9);border:1px solid var(--glow);color:var(--text);font-family:var(--mono);font-size:11px;padding:5px 8px;outline:none;flex:1;}
.voos-input:focus{border-color:var(--blue);}
.voos-search-btn{width:100%;padding:11px;background:transparent;border:1px solid var(--amber);color:var(--amber);font-family:var(--font);font-weight:700;font-size:12px;letter-spacing:0.14em;cursor:pointer;text-transform:uppercase;transition:all 0.2s;position:relative;overflow:hidden;}
.voos-search-btn::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,184,0,0.08),transparent);transition:left 0.4s;}
.voos-search-btn:hover::before{left:100%;}
.voos-search-btn:hover{background:var(--amber-d);}
.voos-search-btn:disabled{color:var(--muted);border-color:var(--muted);cursor:default;}
.voo-card{background:rgba(0,0,0,0.25);border:1px solid var(--border);padding:11px 12px;margin-bottom:6px;transition:border-color 0.2s;}
.voo-card:hover{border-color:var(--amber);}
.voo-card-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:6px;}
.voo-rota{font-size:14px;font-weight:700;letter-spacing:0.05em;color:var(--text);}
.voo-preco{font-family:var(--mono);font-size:15px;font-weight:700;color:var(--green);text-shadow:0 0 8px rgba(0,255,136,0.3);}
.voo-preco-label{font-size:7px;color:var(--muted);letter-spacing:0.08em;text-align:right;margin-top:1px;}
.voo-detalhe{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:6px;}
.voo-tag{font-family:var(--mono);font-size:8px;padding:2px 7px;border-radius:2px;letter-spacing:0.06em;}
.voo-tag.cia{background:rgba(0,180,255,0.08);border:1px solid rgba(0,180,255,0.25);color:var(--blue);}
.voo-tag.escala{background:rgba(255,184,0,0.08);border:1px solid rgba(255,184,0,0.2);color:var(--amber);}
.voo-tag.dur{background:rgba(0,0,0,0.3);border:1px solid var(--border);color:var(--muted);}
.voo-tag.direto{background:rgba(0,255,136,0.06);border:1px solid rgba(0,255,136,0.2);color:var(--green);}
.voo-link{display:block;margin-top:6px;font-family:var(--mono);font-size:9px;padding:5px 10px;border:1px solid rgba(255,184,0,0.3);color:var(--amber);text-decoration:none;text-align:center;letter-spacing:0.08em;transition:all 0.15s;}
.voo-link:hover{background:var(--amber-d);border-color:var(--amber);}
.voo-nota{font-family:var(--mono);font-size:8px;color:var(--muted);line-height:1.5;margin-top:4px;}
.voos-loading{text-align:center;font-family:var(--mono);font-size:10px;color:var(--muted);padding:24px 10px;letter-spacing:0.1em;line-height:2;}
.voos-loading .dot{animation:blink 1.4s infinite;}
.voos-loading .dot:nth-child(2){animation-delay:0.2s;}
.voos-loading .dot:nth-child(3){animation-delay:0.4s;}
.voos-dica{background:rgba(0,180,255,0.04);border:1px solid rgba(0,180,255,0.12);padding:8px 10px;margin-top:8px;}
.voos-dica-title{font-size:8px;color:var(--blue);letter-spacing:0.14em;text-transform:uppercase;margin-bottom:5px;}
.voos-dica-item{font-family:var(--mono);font-size:9px;color:var(--muted);padding:2px 0;line-height:1.5;}
.voos-last{font-family:var(--mono);font-size:8px;color:var(--muted);text-align:right;margin-bottom:6px;letter-spacing:0.06em;}
.voos-date{width:100%;color-scheme:dark;}
.voos-date::-webkit-calendar-picker-indicator{filter:invert(0.6) sepia(1) saturate(3) hue-rotate(175deg);cursor:pointer;padding:2px;}
.voos-pax-btn{background:transparent;border:1px solid var(--amber);color:var(--amber);font-family:var(--mono);font-size:20px;font-weight:700;width:38px;height:38px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all 0.15s;line-height:1;}
.voos-pax-btn:active{background:var(--amber-d);transform:scale(0.92);}
.voos-pax-num{font-family:var(--mono);font-size:26px;font-weight:700;color:var(--amber);text-shadow:0 0 10px rgba(255,184,0,0.3);line-height:1;}
.voo-gf-btn{display:block;width:100%;padding:10px;background:transparent;border:1px solid var(--blue);color:var(--blue);font-family:var(--font);font-weight:700;font-size:11px;letter-spacing:0.12em;cursor:pointer;text-transform:uppercase;text-align:center;text-decoration:none;margin-top:8px;transition:all 0.15s;}
.voo-gf-btn:hover{background:var(--blue-d);}
.voos-tabs{display:flex;gap:0;margin-bottom:10px;border:1px solid var(--border);overflow:hidden;}
.vtab{flex:1;padding:7px 4px;text-align:center;font-size:10px;font-weight:700;letter-spacing:0.06em;text-transform:uppercase;cursor:pointer;background:var(--surface);color:var(--muted);border:none;transition:all 0.15s;font-family:var(--font);border-right:1px solid var(--border);}
.vtab:last-child{border-right:none;}
.vtab.active{background:var(--amber-d);color:var(--amber);border-bottom:2px solid var(--amber);}
.vcontent{display:none;}
.vcontent.active{display:block;}

@keyframes blink{0%,100%{opacity:1}50%{opacity:0.2}}
@keyframes scanh{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.3}}
.panel{animation:fadeIn 0.4s ease both;}
@keyframes fadeIn{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}

/* GLOBE */
.globe-wrap{display:flex;flex-direction:column;align-items:center;padding:10px 0;}
#globe-canvas{border-radius:50%;cursor:grab;touch-action:none;display:block;}
#globe-canvas:active{cursor:grabbing;}
.globe-legend{display:flex;gap:14px;margin-top:10px;font-family:var(--mono);font-size:9px;}
.globe-leg-item{display:flex;align-items:center;gap:5px;}
.globe-leg-dot{width:8px;height:8px;border-radius:50%;}
.globe-leg-dot.visited{background:var(--green);box-shadow:0 0 6px rgba(0,255,136,0.6);}
.globe-leg-dot.unvisited{background:rgba(0,100,180,0.5);border:1px solid rgba(0,180,255,0.3);}
</style>
