async function fetchClimaCoords(lat, lon, label) {
  const icons = {0:'☀️',1:'🌤',2:'⛅',3:'☁️',45:'🌫',48:'🌫',51:'🌦',61:'🌧',71:'🌨',80:'🌦',95:'⛈'};
  const descs = {0:'CEU LIMPO',1:'POUCAS NUVENS',2:'NUBLADO',3:'ENCOBERTO',45:'NEBLINA',51:'CHUVISCO',61:'CHUVA',71:'NEVE',80:'PANCADAS',95:'TEMPESTADE'};
  const r = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current=temperature_2m,weather_code&timezone=America%2FSao_Paulo`);
  if (!r.ok) throw new Error('status ' + r.status);
  const d = await r.json();
  const temp = Math.round(d.current.temperature_2m);
  const code = d.current.weather_code;
  const icon = icons[code] ?? icons[Math.floor(code / 10) * 10] ?? '🌤';
  const desc = descs[code] ?? descs[Math.floor(code / 10) * 10] ?? 'RJ';
  document.getElementById('clima-temp').textContent = temp + '°C';
  document.getElementById('clima-desc').textContent = desc + ' · ' + label.toUpperCase();
  document.getElementById('clima-widget').querySelector('.clima-icon').textContent = icon;
}
async function fetchClima() {
  document.getElementById('clima-temp').textContent = '...';
  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(
      async pos => { try { await fetchClimaCoords(pos.coords.latitude, pos.coords.longitude, 'VOCE'); } catch(e) { await fetchClimaFallback(); } },
      async () => { await fetchClimaFallback(); },
      {timeout: 5000}
    );
  } else { await fetchClimaFallback(); }
}
async function fetchClimaFallback() {
  try { await fetchClimaCoords(-22.9519, -43.1729, 'Botafogo'); }
  catch(e) { document.getElementById('clima-temp').textContent = '--°C'; }
}

