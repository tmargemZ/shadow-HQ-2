function renderPeso() {
  const h = state.weightHistory;
  if (!h.length) return;
  const last = h[h.length - 1];
  const diff = last.val - 68;
  const pct = diff <= 0 ? 100 : Math.max(0, Math.round((1 - diff / 20) * 100));
  document.getElementById('peso-d').textContent = last.val.toFixed(2) + ' kg';
  document.getElementById('peso-b').style.width = pct + '%';
  document.getElementById('peso-s').textContent = diff <= 0 ? '✓ Meta atingida!' : diff.toFixed(2) + ' kg acima da meta de 68 kg';
  const bars = document.getElementById('wc-bars');
  bars.innerHTML = '';
  if (!h.length) { bars.innerHTML = '<span class="wc-empty">sem registros</span>'; return; }
  const vals = h.map(w => w.val);
  const mn = Math.min(...vals) - 0.5, mx = Math.max(...vals) + 0.5;
  h.forEach(w => {
    const ph = mx === mn ? 50 : Math.round(((w.val - mn) / (mx - mn)) * 100);
    const col = document.createElement('div');
    col.className = 'wc-col';
    col.innerHTML = `<div class="wc-v">${w.val.toFixed(1)}</div><div class="wc-bar" style="height:${Math.max(4, ph)}%"></div><div class="wc-day">${w.day}</div>`;
    bars.appendChild(col);
  });
